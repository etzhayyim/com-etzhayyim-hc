{
  "@context": "https://etzhayyim.com/ns/actor/v1",
  "@id": "did:web:hc.etzhayyim.com",
  "actors": [
    {
      "description": "ギグ/タスクワーカー利用規約 (13 locale)",
      "displayName": "Worker Agreement",
      "path": "legal:workerAgreement"
    },
    {
      "description": "OEM 製造者サービス契約",
      "displayName": "SP Service Agreement",
      "path": "legal:spServiceAgreement"
    },
    {
      "description": "マイクロタスク個別条件",
      "displayName": "Task Terms",
      "path": "legal:taskTerms"
    },
    {
      "description": "シフトワーク個別条件",
      "displayName": "Shift Terms",
      "path": "legal:shiftTerms"
    }
  ],
  "capabilities": [
    "graph.query",
    "graph.write",
    "agent.chat",
    "agent.invoke",
    "derive:social"
  ],
  "complianceDocs": [
    "90-docs/rules/compliance/per-did-kyumei-shinka-autonomy.md",
    "90-docs/platform/260403-live-data-kyumei-shinka-consolidated.md"
  ],
  "convoSystemPrompt": "You are the HC agent — a Human Computing platform combining Timee-style gig work and MTurk-style micro-tasks. You manage tasks, shifts, worker bookings, SP onboarding (KYC/KYB → factory audit → tsukuru registration), compliance checks (Japanese labor law), and quality inspections. Use graph queries for data. Invoke tsukuru, legal-entity, yabai for cross-app operations.",
  "description": "Timee-style ギグワーク + MTurk-style マイクロタスクのハイブリッドプラットフォーム。日本の労働基準法準拠。OEM SP 登録パイプライン。",
  "displayName": "HC — Human Computing Platform (スキマバイト + マイクロタスク)",
  "domainKnowledgeRequired": true,
  "runtime": "k8s-langserver",
  "edge": "sveltekit-proxy",
  "legacyExecutionTier": "T1",
  "governance": {
    "classification": "internal",
    "complianceFrameworks": [
      "労働基準法",
      "最低賃金法",
      "GDPR"
    ],
    "raci": "responsible"
  },
  "heartbeatRequired": true,
  "name": "hc",
  "nanoid": "hc0mp7ng",
  "performerType": "service",
  "pipelines": [
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (n:Task) RETURN n.vertex_id, n.rkey, n.repo, n.did, n.status, n.props, n._seq ORDER BY n.createdAt DESC SKIP $input.offset LIMIT $input.limit"
          },
          "fn": "graph.query",
          "id": "tasks"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.hc.listHc",
        "type": "xrpc"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (n:Task) WHERE n.name CONTAINS $input.q OR n.description CONTAINS $input.q RETURN n.vertex_id, n.rkey, n.repo, n.did, n.status, n.props, n._seq LIMIT $input.limit"
          },
          "fn": "graph.query",
          "id": "results"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.hc.searchHc",
        "type": "xrpc"
      }
    },
    {
      "steps": [
        {
          "args": {
            "template": "CREATE (t:Task {did: $did, val: $input.record, status: 'active', repo: $did, collection: 'com.etzhayyim.apps.hc.task'})"
          },
          "fn": "graph.write",
          "id": "create"
        },
        {
          "args": {
            "message": "You are HC — Human Computing Platform (スキマバイト + マイクロタスク). Based on the following new data, write a concise social post (1-2 sentences, informative and specific). Data: $create.text"
          },
          "depends_on": [
            "create"
          ],
          "fn": "agent.chat",
          "id": "compose"
        },
        {
          "args": {
            "template": "$compose.text"
          },
          "depends_on": [
            "compose"
          ],
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.hc.createHc",
        "type": "xrpc"
      }
    },
    {
      "steps": [
        {
          "args": {
            "template": "CREATE (sp:HcSpApplication {did: $did, legalName: $input.legalName, countryIso3: $input.countryIso3, category: $input.category, status: 'pendingKyc', repo: $did, collection: 'com.etzhayyim.apps.hc.spApplication'})"
          },
          "fn": "graph.write",
          "id": "writeSp"
        },
        {
          "args": {
            "template": "CREATE (t:Task {did: $did, title: 'KYC/KYB Review: ' + $input.legalName, category: 'sp-kyc-review', difficulty: 'medium', status: 'published', repo: $did, collection: 'com.etzhayyim.apps.hc.task'})"
          },
          "depends_on": [],
          "fn": "graph.write",
          "id": "kycTask"
        },
        {
          "args": {
            "message": "You are HC — Human Computing Platform (スキマバイト + マイクロタスク). Based on the following new data, write a concise social post (1-2 sentences, informative and specific). Data: $kycTask.text"
          },
          "depends_on": [
            "kycTask"
          ],
          "fn": "agent.chat",
          "id": "compose"
        },
        {
          "args": {
            "template": "$compose.text"
          },
          "depends_on": [
            "compose"
          ],
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.hc.createSpApplication",
        "type": "xrpc"
      }
    },
    {
      "steps": [
        {
          "args": {
            "message": "SP verification result received: $input.record\n\nIf result is 'approved', generate a factory audit task. If 'rejected', note the reason. Return JSON: {nextAction, reason}"
          },
          "fn": "agent.chat",
          "id": "checkResult"
        },
        {
          "args": {
            "template": "MERGE (a:HcSpAction {did: $did}) SET a.action = $checkResult.text, a.repo = $did, a.collection = 'com.etzhayyim.apps.hc.spAction'"
          },
          "fn": "graph.write",
          "id": "writeAction"
        },
        {
          "args": {
            "template": "New data added: $checkResult.text"
          },
          "depends_on": [
            "checkResult"
          ],
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "collections": [
          "com.etzhayyim.apps.hc.spVerification"
        ],
        "type": "subscribeRepos"
      }
    },
    {
      "steps": [
        {
          "args": {
            "message": "Factory audit result received: $input.record\n\nIf result is 'pass', the SP is ready for tsukuru registration. Summarize findings."
          },
          "fn": "agent.chat",
          "id": "auditResult"
        },
        {
          "args": {
            "args": {
              "applicationId": "$input.record.applicationId",
              "source": "hcPipeline"
            },
            "method": "registerManufacturer",
            "targetDid": "did:web:tsukuru.etzhayyim.com"
          },
          "depends_on": [],
          "fn": "agent.invoke",
          "id": "registerTsukuru"
        },
        {
          "args": {
            "template": "SP 工場監査完了 → tsukuru 登録: $auditResult.text"
          },
          "depends_on": [
            "auditResult"
          ],
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "collections": [
          "com.etzhayyim.apps.hc.spAudit"
        ],
        "type": "subscribeRepos"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (n:Task) WHERE n.actorId = 'hc0mp7ng' RETURN n.name AS name, n.status AS status LIMIT 10"
          },
          "fn": "graph.query",
          "id": "data"
        },
        {
          "args": {
            "message": "Summarize HC platform data: $data.rows\n\nBe concise. Include task counts by status."
          },
          "fn": "agent.chat",
          "id": "summary"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.hc.summarizeHc",
        "type": "xrpc"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (n:Task) WHERE n.actorId = 'hc0mp7ng' RETURN n.status AS status, count(n) AS cnt LIMIT 20"
          },
          "fn": "graph.query",
          "id": "dailyStats"
        },
        {
          "args": {
            "sql": "MATCH (sp:HcSpApplication) RETURN sp.status AS status, count(sp) AS cnt LIMIT 10"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "spStats"
        },
        {
          "args": {
            "message": "Daily HC platform briefing.\n\nTask stats:\n$dailyStats.rows\n\nSP application stats:\n$spStats.rows\n\nHighlight key metrics and any items needing attention."
          },
          "depends_on": [
            "dailyStats",
            "spStats"
          ],
          "fn": "agent.chat",
          "id": "briefing"
        },
        {
          "args": {
            "template": "HC 日報: $briefing.text"
          },
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "cron": "0 9 * * *",
        "type": "cron"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (n) WHERE n.repo = $did RETURN count(n) AS nodeCount, coalesce(max(n._seq), 0) AS latestSeq LIMIT 1"
          },
          "fn": "graph.query",
          "id": "coverageNodes"
        },
        {
          "args": {
            "sql": "MATCH (n) WHERE n.repo = $did AND n.collection IS NOT NULL RETURN n.collection AS collection, count(n) AS cnt ORDER BY cnt DESC LIMIT 10"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageCollections"
        },
        {
          "args": {
            "params": {
              "actorName": "hc",
              "bucket": "6h",
              "collection": "com.etzhayyim.apps.hc.coverageSnapshot",
              "latestSeq": 0,
              "nanoid": "hc0mp7ng",
              "nodeCount": "$coverageNodes.rows[0].nodeCount"
            },
            "template": "MERGE (c:ActorCoverageSnapshot {actorDid: $did, bucket: $bucket, actorName: $actorName, nanoid: $nanoid, nodeCount: $nodeCount, latestTs: $latestTs, repo: $did, collection: $collection, status: 'active'})"
          },
          "depends_on": [
            "coverageNodes"
          ],
          "fn": "graph.write",
          "id": "coverageSnapshot"
        },
        {
          "args": {
            "message": "You are HC — Human Computing Platform (スキマバイト + マイクロタスク). Based on the following new data, write a concise social post (1-2 sentences, informative and specific). Data: $coverageSnapshot.text"
          },
          "depends_on": [
            "coverageSnapshot"
          ],
          "fn": "agent.chat",
          "id": "compose"
        },
        {
          "args": {
            "template": "$compose.text"
          },
          "depends_on": [
            "compose"
          ],
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "cron": "0 */6 * * *",
        "type": "cron"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (c:ActorCoverageSnapshot {actorDid: $did}) RETURN c.nodeCount AS nodeCount, c.latestSeq AS latestSeq, c.topCollections AS topCollections, c._seq AS snapshotSeq LIMIT 1"
          },
          "fn": "graph.query",
          "id": "coverageStats"
        },
        {
          "args": {
            "sql": "MATCH (c:ActorCoverageSnapshot {actorDid: $did}) RETURN c.nodeCount AS totalNodes LIMIT 1"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageHealth"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.hc.coverage.get",
        "type": "xrpc"
      }
    }
  ],
  "profile": {
    "agentType": "autonomous",
    "capabilities": [
      "task-management",
      "shift-management",
      "sp-onboarding",
      "kyc-verification",
      "compliance-check",
      "quality-inspection"
    ],
    "country": "jpn",
    "description": "Timee-style ギグワーク + MTurk-style マイクロタスク。労働基準法準拠、OEM サービスプロバイダー登録パイプライン、Murakumo クレジット連携。",
    "displayName": "HC — Human Computing Platform",
    "isBot": true,
    "operator": "etzhayyim.co.jp"
  },
  "requiredCollections": [
    "com.etzhayyim.apps.standard.shinkaEvolution",
    "com.etzhayyim.apps.standard.shinkaKnowledge"
  ],
  "requiredLoops": [
    "shinka",
    "koji",
    "kyumei",
    "domain-knowledge"
  ],
  "standardRule": "per-did-kyumei-shinka-autonomy@2026-04-13",
  "standardStatus": "required",
  "triggers": {
    "subscribeRepos": {
      "collections": [
        "com.etzhayyim.apps.hc.task",
        "com.etzhayyim.apps.hc.spApplication",
        "com.etzhayyim.apps.hc.spVerification",
        "com.etzhayyim.apps.hc.spAudit",
        "com.etzhayyim.apps.tsukuru.manufacturer"
      ]
    }
  },
  "uiType": "yoro"
}
